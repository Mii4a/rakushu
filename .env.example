# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-string

# Turso
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ODPT / GTFS downloads
ODPT_ACCESS_TOKEN=

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Maps Platform
# Server-side only: Routes API / Geocoding API
GOOGLE_MAPS_SERVER_API_KEY=
# Browser-side only: Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_API_KEY=

# Stripe subscriptions
# Secret key from Stripe Dashboard
STRIPE_SECRET_KEY=
# Signing secret for POST /api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Recurring monthly price IDs
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=
# true: allow any promotion code entered in Checkout
STRIPE_ALLOW_PROMOTION_CODES=true
# Optional fixed promotion code to auto-apply in Checkout
STRIPE_CAMPAIGN_PROMOTION_CODE_ID=

# Google Search Console / site verification
# Preferred name
GOOGLE_SEARCH_CONSOLE_SITE_VERIFICATION=
# Backward-compatible alias
GOOGLE_SITE_VERIFICATION=

# OpenAI
OPENAI_API_KEY=
OPENAI_MAIN_MODEL=gpt-4.1-mini
OPENAI_LIGHT_MODEL=gpt-4.1-nano

# Internal tools access allowlist (comma-separated emails)
INTERNAL_TOOL_EMAILS=owner@example.com,reviewer@example.com
# Internal admins can see all internal feedback rows
INTERNAL_ADMIN_EMAILS=owner@example.com
