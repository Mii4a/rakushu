{
  "name": "rakushu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "clean": "rm -rf .next",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src tests scripts next.config.ts tailwind.config.ts vitest.config.ts playwright.prod-smoke.config.ts open-next.config.ts eslint.config.mjs",
    "preview": "node scripts/run-opennext-production.mjs .env.production preview",
    "deploy": "node scripts/run-opennext-production.mjs .env.production deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:secrets:prod": "node scripts/push-cloudflare-secrets.mjs .env.production",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- node scripts/migrate-turso.mjs",
    "db:migrate:prod": "dotenv -e .env.production -- node scripts/migrate-turso.mjs",
    "db:migrate:status": "dotenv -e .env.local -- node scripts/check-turso-migration-status.mjs",
    "db:migrate:prod:status": "dotenv -e .env.production -- node scripts/check-turso-migration-status.mjs",
    "db:backfill:raw-text-null": "dotenv -e .env.local -- node scripts/backfill-job-raw-text-null.mjs --apply",
    "db:backfill:raw-text-null:prod": "dotenv -e .env.production -- node scripts/backfill-job-raw-text-null.mjs --apply",
    "db:backfill:commute": "dotenv -e .env.local -- node --import tsx scripts/backfill-gtfs-commute-ranges.ts",
    "db:import:gtfs": "dotenv -e .env.local -- node scripts/import-gtfs-manifest.mjs",
    "db:sync:gtfs": "dotenv -e .env.local -- node scripts/sync-gtfs-feeds.mjs",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:local-jobs-smoke": "playwright test -c playwright.local-jobs-smoke.config.ts",
    "test:prod-smoke": "playwright test -c playwright.prod-smoke.config.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@opennextjs/cloudflare": "^1.19.4",
    "better-auth": "^1.3.7",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^18.1.1",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.25.0",
    "eslint-config-next": "^15.3.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.85.0"
  }
}
